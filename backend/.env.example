# ── LLM (at least one required) ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AI...

# Which model to use (litellm provider/model string)
LLM_MODEL=anthropic/claude-3-5-sonnet-20241022

# ── Database & Redis ──────────────────────────────────────────────
# For Docker Compose these are injected automatically.
# For Railway / production, set these to your hosted service URLs.
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
REDIS_URL=redis://default:password@host:6379

# ── Security ──────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string

# Optional: Fernet key for MFA secret encryption.
# Auto-derived from JWT_SECRET_KEY if left blank.
MFA_ENCRYPTION_KEY=

# ── OAuth SSO (optional) ──────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── URLs ──────────────────────────────────────────────────────────
# Set these to your deployed frontend/backend URLs in production.
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
